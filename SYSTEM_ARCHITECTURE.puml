@startuml ERP_Cloud_Architecture

!define ENTITY_COLOR #FF6B6B
!define SERVICE_COLOR #4ECDC4
!define HANDLER_COLOR #FFE66D
!define VO_COLOR #95E1D3
!define REPO_COLOR #A8D8EA
!define EVENT_COLOR #F7DC6F
!define CONTROLLER_COLOR #BB8FCE

skinparam componentBackgroundColor #F5F5F5
skinparam backgroundColor #FFFFFF

title ERP Cloud - Arquitetura do Sistema Completo

' ============================================================================
' CAMADA DE APRESENTAÇÃO (REST API)
' ============================================================================

package "REST API Layer" {
    component [UsuarioController] as UC CONTROLLER_COLOR
    component [ProdutoController] as PC CONTROLLER_COLOR
    component [ClienteController] as CC CONTROLLER_COLOR
    component [EnderecoController] as EC CONTROLLER_COLOR
    component [PermissaoController] as PerC CONTROLLER_COLOR
    component [UnidadeMedidaController] as UMC CONTROLLER_COLOR
    component [TenantController] as TC CONTROLLER_COLOR
    component [ObservabilityController] as OC CONTROLLER_COLOR
}

' ============================================================================
' CAMADA DE APLICAÇÃO (Services, Handlers, Commands)
' ============================================================================

package "Application Layer" {
    package "User Feature" {
        component [UsuarioService] as US SERVICE_COLOR
        component [CreateUserHandler] as CUH HANDLER_COLOR
        component [ActivateUserHandler] as AUH HANDLER_COLOR
    }
    
    package "Produto Feature" {
        component [ProdutoService] as ProdS SERVICE_COLOR
        component [CreateProdutoHandler] as CPH HANDLER_COLOR
    }
    
    package "Cliente Feature" {
        component [ClienteService] as ClienteS SERVICE_COLOR
        component [CreateClienteHandler] as CCH HANDLER_COLOR
    }
    
    package "Endereco Feature" {
        component [EnderecoService] as EndS SERVICE_COLOR
    }
    
    package "Permissao Feature" {
        component [PermissaoService] as PermS SERVICE_COLOR
    }
    
    package "Observability" {
        component [ObservabilityService] as ObsS SERVICE_COLOR
        component [FlowEventPublisher] as FEP EVENT_COLOR
    }
}

' ============================================================================
' CAMADA DE DOMÍNIO (Aggregates, Value Objects, Events)
' ============================================================================

package "Domain Layer" {
    package "User Aggregate" {
        component [Usuario] as EntUsuario ENTITY_COLOR
        component [UsuarioRole] as UR ENTITY_COLOR
        component [UsuarioPermissao] as UP ENTITY_COLOR
        component [UserEmail] as UE VO_COLOR
        component [CPF] as CPF_VO VO_COLOR
        component [UserCreatedEvent] as UCE EVENT_COLOR
        component [UserActivatedEvent] as UAE EVENT_COLOR
    }
    
    package "Produto Aggregate" {
        component [Produto] as EntProd ENTITY_COLOR
        component [ProdutoComposicao] as ProdComp ENTITY_COLOR
        component [NCM] as NCM_VO VO_COLOR
    }
    
    package "Cliente Aggregate" {
        component [Cliente] as EntCliente ENTITY_COLOR
        component [ClienteContato] as CC_Dom ENTITY_COLOR
    }
    
    package "Endereco Aggregate" {
        component [Endereco] as EntEndereco ENTITY_COLOR
    }
    
    package "Tenant Aggregate" {
        component [Tenant] as EntTenant ENTITY_COLOR
        component [TenantDatasource] as TD ENTITY_COLOR
    }
    
    package "Observability Aggregate" {
        component [FlowEvent] as FE EVENT_COLOR
    }
}

' ============================================================================
' CAMADA DE INFRAESTRUTURA (Persistence, Mappers, Repositories)
' ============================================================================

package "Infrastructure Layer" {
    package "User Module" {
        component [UsuarioEntity] as UE_Inf ENTITY_COLOR
        component [UsuarioRepository] as UR_Inf REPO_COLOR
        component [UsuarioMapper] as UMapper
    }
    
    package "Produto Module" {
        component [ProdutoEntity] as PE_Inf ENTITY_COLOR
        component [ProdutoRepository] as PR_Inf REPO_COLOR
    }
    
    package "Cliente Module" {
        component [ClienteEntity] as CLE_Inf ENTITY_COLOR
        component [ClienteRepository] as CRep REPO_COLOR
    }
    
    package "Endereco Module" {
        component [EnderecoEntity] as EE_Inf ENTITY_COLOR
        component [EnderecoRepository] as ER_Inf REPO_COLOR
    }
    
    package "Tenant Configuration" {
        component [MultiTenantRoutingDataSource] as MTDS
        component [TenantContextInterceptor] as TCI
    }
    
    package "Observability" {
        component [FlowEventRepository] as FER REPO_COLOR
        component [KafkaTracker] as KT
        component [WebSocketTracker] as WST
    }
}

' ============================================================================
' CAMADA DE DADOS (Databases)
' ============================================================================

package "Data Layer" {
    database "PostgreSQL Tenant DB" as DB_Tenant
    database "PostgreSQL Observability" as DB_Obs
    component [Kafka Broker] as Kafka
}

' ============================================================================
' RELACIONAMENTOS
' ============================================================================

' REST → Application
UC --> US : calls
PC --> ProdS : calls
CC --> ClienteS : calls
EC --> EndS : calls
PerC --> PermS : calls
TC --> TCI : routes
OC --> ObsS : calls

' Application → Handlers
US --> CUH : uses
US --> AUH : uses
ProdS --> CPH : uses
ClienteS --> CCH : uses

' Handlers → Aggregates
CUH --> EntUsuario : creates
CUH --> UCE : generates
AUH --> EntUsuario : updates
AUH --> UAE : generates
CPH --> EntProd : creates

' Handlers → Repositories
CUH --> UR_Inf : persists
CPH --> PR_Inf : persists

' Application Services → Repositories
US --> UR_Inf : queries
ProdS --> PR_Inf : queries
ClienteS --> CRep : queries
EndS --> ER_Inf : queries
ObsS --> FER : persists

' Aggregates with ValueObjects
EntUsuario *-- UR : contains
EntUsuario *-- UP : contains
EntUsuario *-- UE : contains

EntProd *-- ProdComp : contains
EntProd *-- NCM_VO : contains

' Repositories → Database
UR_Inf --> DB_Tenant : persists
PR_Inf --> DB_Tenant : persists
CRep --> DB_Tenant : persists
ER_Inf --> DB_Tenant : persists
FER --> DB_Obs : persists

' Multi-Tenancy
TCI --> MTDS : manages
MTDS --> DB_Tenant : routes

' Observability Events
ObsS --> FER : creates FlowEvent
FEP --> Kafka : publishes

' ============================================================================
' NOTAS E LEGENDAS
' ============================================================================

note right of EntUsuario
  v1/features/usuario/domain/entity/
  WARNING: Acoplado com @Entity
  Deveria ser Domain puro
end note

note right of UR_Inf
  v1/features/usuario/domain/repository/
  Abstração de persistência
end note

note right of MTDS
  Suporte a múltiplos tenants
  Cada tenant tem seu DataSource
end note

legend right
  |<#FF6B6B> Entity |
  |<#4ECDC4> Service |
  |<#FFE66D> Handler |
  |<#95E1D3> Value Object |
  |<#A8D8EA> Repository |
  |<#F7DC6F> Event |
endlegend

footer ERP Cloud Architecture - Fevereiro 2026

@enduml
