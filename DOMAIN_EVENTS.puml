@startuml ERP_Cloud_Domain_Events

!define COLOR_EVENT #F7DC6F
!define COLOR_HANDLER_EVT #FFE66D
!define COLOR_DOMAIN #FFFACD
!define COLOR_APP #E6F3FF
!define COLOR_SUB #95E1D3

skinparam backgroundColor #FFFFFF
skinparam componentBackgroundColor #F5F5F5

title ERP Cloud - Domain Events & Event-Driven Architecture

' ============================================================================
' DOMAIN EVENTS GENERATION
' ============================================================================

rectangle "🎯 DOMAIN EVENT GENERATION" #FFFACD {
    component [User.create()] as USER_CREATE
    component [User.addRole()] as USER_ADD_ROLE
    component [User.grantPermission()] as USER_GRANT_PERM
    component [User.activate()] as USER_ACTIVATE
    component [User.deactivate()] as USER_DEACTIVATE
    
    component [Produto.create()] as PROD_CREATE
    component [Produto.updateStock()] as PROD_UPDATE
    
    component [Cliente.create()] as CLIENT_CREATE
    component [Cliente.addContato()] as CLIENT_CONTATO
}

' ============================================================================
' EVENTS ENUM
' ============================================================================

rectangle "📋 DOMAIN EVENT TYPES" #F7DC6F {
    component [UserCreatedEvent] as EVT_UC
    component [UserRoleAddedEvent] as EVT_URA
    component [UserPermissionGrantedEvent] as EVT_UPG
    component [UserActivatedEvent] as EVT_UA
    component [UserDeactivatedEvent] as EVT_UD
    
    component [ProdutoCreatedEvent] as EVT_PC
    component [ProdutoStockUpdatedEvent] as EVT_PSU
    
    component [ClienteCreatedEvent] as EVT_CC
    component [ClienteContatoAddedEvent] as EVT_CCA
}

USER_CREATE --> EVT_UC : generates
USER_ADD_ROLE --> EVT_URA : generates
USER_GRANT_PERM --> EVT_UPG : generates
USER_ACTIVATE --> EVT_UA : generates
USER_DEACTIVATE --> EVT_UD : generates

PROD_CREATE --> EVT_PC : generates
PROD_UPDATE --> EVT_PSU : generates

CLIENT_CREATE --> EVT_CC : generates
CLIENT_CONTATO --> EVT_CCA : generates

' ============================================================================
' EVENT STRUCTURE
' ============================================================================

rectangle "🏗️ EVENT STRUCTURE" {
    note right
        **DomainEvent Base**
        ```
        {
          aggregateId: UUID
          aggregateType: String (e.g., "User")
          eventType: String (e.g., "UserCreated")
          tenantId: Long
          userId: Long (who triggered)
          occurredOn: Instant
          version: Integer (aggregate version)
          eventPayload: Map<String, Object>
          traceId: String (for observability)
        }
        ```
        
        **Example: UserCreatedEvent**
        ```
        {
          aggregateId: user-123-uuid
          aggregateType: "User"
          eventType: "UserCreated"
          tenantId: 100
          userId: null (system)
          occurredOn: 2026-02-14T10:30:00Z
          eventPayload: {
            email: "joao@example.com",
            name: "João Silva",
            status: "INACTIVE"
          }
          traceId: abc-def-123
        }
        ```
    end note
}

' ============================================================================
' EVENT STORAGE
' ============================================================================

rectangle "💾 EVENT PERSISTENCE" #FFE6E6 {
    component [EventStore] as EVT_STORE
    component [DomainEventRepository] as EVT_REPO
    component [PostgreSQL EventLog] as PG_EVT
    
    component [Aggregate Root] as AGG
    component [pullDomainEvents()] as PULL_EVENTS
    component [eventRepository.save()] as SAVE_EVT
}

EVT_UC --> EVT_STORE : store
EVT_UA --> EVT_STORE : store
EVT_PC --> EVT_STORE : store

AGG --> PULL_EVENTS : get all unpublished
PULL_EVENTS --> SAVE_EVT : persist before publish
SAVE_EVT --> EVT_REPO : repository
EVT_REPO --> PG_EVT : PostgreSQL

' ============================================================================
' EVENT PUBLICATION & CONSUMPTION
' ============================================================================

rectangle "📡 EVENT PUBLICATION" #E6F3FF {
    component [DomainEventPublisher] as PUB
    component [EventPublished Flag] as FLAG
    component [ApplicationEventPublisher] as APP_PUB
    component [DomainEventDispatcher] as DISPATCHER
}

SAVE_EVT --> PUB : after persist
PUB --> FLAG : mark published
FLAG --> APP_PUB : Spring ApplicationEventPublisher
APP_PUB --> DISPATCHER : dispatch to subscribers

' ============================================================================
' EVENT SUBSCRIBERS (USE CASES)
' ============================================================================

rectangle "🔊 EVENT SUBSCRIBERS (Use Cases)" #95E1D3 {
    package "User Domain Subscribers" {
        component [SendWelcomeEmailOnUserCreated] as SUB1
        component [NotifyAdminOnRoleAdded] as SUB2
        component [UpdateUserIndexOnActivated] as SUB3
        component [ArchiveUserDataOnDeactivated] as SUB4
    }
    
    package "Produto Domain Subscribers" {
        component [UpdateInventoryOnCreated] as SUB5
        component [SendStockAlertOnUpdate] as SUB6
    }
    
    package "Cliente Domain Subscribers" {
        component [SendWelcomeOnCreated] as SUB7
        component [SendContatoConfirmationOnAdded] as SUB8
    }
    
    package "Cross-Domain Subscribers" {
        component [LogToObservability] as SUB_LOG
        component [PublishToKafka] as SUB_KAFKA
        component [SendWebSocketNotification] as SUB_WS
    }
}

DISPATCHER --> SUB1 : route UserCreatedEvent
DISPATCHER --> SUB2 : route UserRoleAddedEvent
DISPATCHER --> SUB3 : route UserActivatedEvent
DISPATCHER --> SUB4 : route UserDeactivatedEvent

DISPATCHER --> SUB5 : route ProdutoCreatedEvent
DISPATCHER --> SUB6 : route ProdutoStockUpdatedEvent

DISPATCHER --> SUB7 : route ClienteCreatedEvent
DISPATCHER --> SUB8 : route ClienteContatoAddedEvent

DISPATCHER --> SUB_LOG : all events
DISPATCHER --> SUB_KAFKA : all events
DISPATCHER --> SUB_WS : all events

' ============================================================================
' USE CASE DETAILS
' ============================================================================

rectangle "📬 SPECIFIC USE CASE FLOWS" {
    note right
        **1️⃣ Email Notification on User Creation**
        
        UserCreatedEvent published
           ↓
        SendWelcomeEmailOnUserCreated listener triggered
           ↓
        Extract email from event payload
           ↓
        Send email via SMTP (async)
           ↓
        Log success/failure to observability
        
        ---
        
        **2️⃣ Inventory Update on Product Creation**
        
        ProdutoCreatedEvent published
           ↓
        UpdateInventoryOnCreated listener triggered
           ↓
        Create inventory record linked to product
           ↓
        Set initial stock = 0
           ↓
        Publish InventoryCreatedEvent (cascade)
        
        ---
        
        **3️⃣ Cross-Domain: Observability Logging**
        
        ANY DomainEvent published
           ↓
        LogToObservability listener triggered
           ↓
        Create FlowEvent from DomainEvent
           ↓
        Store in observability database
           ↓
        Publish to Kafka & WebSocket
    end note
}

' ============================================================================
' CONSEQUENCES & BENEFITS
' ============================================================================

rectangle "✅ BENEFITS OF DOMAIN EVENTS" {
    note right
        **Auditoria Completa**
        └─ Histórico imutável de tudo que aconteceu
        
        **Eventual Consistency**
        └─ Listeners podem ser assíncronos
        └─ Sistemas distribuídos sincronizados via eventos
        
        **Acoplamento Reduzido**
        └─ Agregados não conhecem subscribers
        └─ Fácil adicionar novo comportamento
        
        **Testabilidade**
        └─ Listeners testáveis isoladamente
        └─ Mock DomainEventPublisher em testes
        
        **Replay Capability**
        └─ Reconstruir estado em ponto no tempo
        └─ Debug de bugs complexos
        
        **Real-time Notifications**
        └─ Webhooks, WebSockets, Push notifications
        └─ UI sempre sincronizada com estado
        
        **Analytics**
        └─ Kafka publica eventos
        └─ Elasticsearch/datadog consumem
        └─ Dashboards em tempo real
    end note
}

' ============================================================================
' FAILURE HANDLING
' ============================================================================

rectangle "⚠️ FAILURE & RETRY STRATEGIES" #FFE6E6 {
    component [Event Publication Fails] as FAIL_PUB
    component [Subscriber Throws Exception] as FAIL_SUB
    component [Retry Mechanism] as RETRY
    component [Dead Letter Queue] as DLQ
    component [Alert Admin] as ALERT
}

PUB -.-> FAIL_PUB : if publish fails
FAIL_PUB --> RETRY : exponential backoff
RETRY --> FAIL_PUB : retry up to 3x
FAIL_PUB --> DLQ : if still fails
DLQ --> ALERT : notification

APP_PUB -.-> FAIL_SUB : if listener fails
FAIL_SUB --> RETRY : retry
RETRY --> FAIL_SUB : attempt again
FAIL_SUB --> DLQ : exhausted retries

' ============================================================================
' COMPARISON: CURRENT vs IDEAL
' ============================================================================

rectangle "📊 IMPLEMENTATION STATUS" {
    note right
        **✅ IMPLEMENTED**
        • Aggregates (Usuario, Produto, Cliente)
        • Basic operation (create, update)
        • Services for persistence
        
        ---
        
        **❌ NOT IMPLEMENTED**
        • DomainEvent generation in aggregates
        • DomainEventRepository
        • DomainEventPublisher
        • Event Subscribers/Listeners
        • Event Sourcing
        • Event replay mechanisms
        
        ---
        
        **Current State: ~50%**
        Aggregates exist but don't generate events
        
        **Target State: 100%**
        Full event-driven architecture
        with audit trail and observers
    end note
}

footer ERP Cloud - Domain Events Architecture | Fevereiro 2026

@enduml
