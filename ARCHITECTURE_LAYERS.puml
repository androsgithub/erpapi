@startuml ERP_Cloud_Layered_Architecture

!define COLOR_PRESENTATION #E6FFE6
!define COLOR_APPLICATION #E6F3FF
!define COLOR_DOMAIN #FFFACD
!define COLOR_INFRASTRUCTURE #FFE6E6

skinparam backgroundColor #FFFFFF
skinparam componentBackgroundColor #F5F5F5
skinparam componentBorderColor #333333
skinparam packageBackgroundColor #FFFFFF
skinparam packageBorderColor #333333

title ERP Cloud - Arquitetura em Camadas

' ============================================================================
' APRESENTAÇÃO
' ============================================================================

rectangle  "🌐 PRESENTATION LAYER" #E6FFE6 {
    package "REST Controllers" {
        rectangle "POST /usuarios" as R1
        rectangle "GET /usuarios/{id}" as R2
        rectangle "PUT /usuarios/{id}" as R3
        rectangle "DELETE /usuarios/{id}" as R4
        rectangle "POST /usuarios/{id}/roles" as R5
        rectangle "POST /usuarios/{id}/permissions" as R6
    }
    
    package "Request/Response DTOs" {
        rectangle "CreateUserRequest\nCreateUserResponse" as DTO1
        rectangle "UserRoleRequest\nUserPermissionRequest" as DTO2
    }
    
    package "Input Validation" {
        rectangle "Format Validation\nRange Validation\nBusiness Rule Validation" as VAL1
    }
}

' ============================================================================
' APLICAÇÃO
' ============================================================================

rectangle "📋 APPLICATION LAYER" #E6F3FF {
    package "Commands (CQRS)" {
        rectangle "CreateUserCommand\nActivateUserCommand\nChangeEmailCommand\nChangePasswordCommand\nAddUserRoleCommand\nGrantPermissionCommand" as CMD
    }
    
    package "Handlers/Services" {
        rectangle "CreateUserHandler\nActivateUserHandler\nChangeEmailHandler\nChangePasswordHandler\nAddRoleHandler" as HAND
    }
    
    package "Orchestration" {
        rectangle "Transaction Management\nEvent Publishing\n@TrackFlow Aspects\nValidation Coordination" as ORCH
    }
    
    package "Queries (CQRS)" {
        rectangle "FindUserByIdQuery\nListUsersByTenantQuery\nGetUserPermissionsQuery\nGetUserRolesQuery" as QRY
    }
}

' ============================================================================
' DOMÍNIO
' ============================================================================

rectangle "🏗️ DOMAIN LAYER" #FFFACD {
    package "Aggregates" {
        rectangle "User Aggregate Root\n├─ UserId (VO)\n├─ UserEmail (VO)\n├─ UserPassword (VO)\n├─ Set<UserRole> (VO)\n├─ Set<UserPermission> (VO)\n└─ UserStatus (Enum)" as AGG1
        
        rectangle "Produto Aggregate Root\n├─ ProdutoId (VO)\n├─ NCM (VO)\n├─ OrigemMercadoria (VO)\n├─ ProdutoComposicao\n└─ Validações de negócio" as AGG2
        
        rectangle "Tenant Aggregate Root\n├─ TenantId (VO)\n├─ TenantGroup\n├─ TenantDatasource\n└─ Isolamento de dados" as AGG3
    }
    
    package "Value Objects" {
        rectangle "Imutáveis e Validados:\n• Email\n• CPF\n• NCM\n• OrigemMercadoria\n• Endereco" as VO
    }
    
    package "Domain Events" {
        rectangle "UserCreatedEvent\nUserActivatedEvent\nUserRoleAddedEvent\nUserPermissionGrantedEvent\nProdutoCreatedEvent\nClienteCreatedEvent" as DEVT
    }
    
    package "Business Rules" {
        rectangle "User invariants:\n✓ Ativo deve ter ≥1 role\n✓ Email único por tenant\n✓ Senha sempre hash\n\nProduto invariants:\n✓ NCM obrigatório\n✓ Quantidade > 0\n\nTenant invariants:\n✓ Um datasource ativo\n✓ Isolamento completo" as BR
    }
}

' ============================================================================
' INFRAESTRUTURA
' ============================================================================

rectangle "🔧 INFRASTRUCTURE LAYER" #FFE6E6 {
    package "Repository Implementations" {
        rectangle "UserRepositoryJPA\n├─ findById()\n├─ save()\n├─ findByEmailInTenant()\n└─ findRolesByUser()" as REPO1
        
        rectangle "ProdutoRepositoryJPA\n├─ findById()\n├─ save()\n└─ findByTenant()" as REPO2
        
        rectangle "GenericRepository<T>\n(Base implementation)" as REPO3
    }
    
    package "Entity Mappers" {
        rectangle "UserMapper\n(User ↔ UserEntity)\nDomain ↔ Persistence" as MAP1
        
        rectangle "ProdutoMapper\n(Produto ↔ ProdutoEntity)" as MAP2
    }
    
    package "Persistence Models" {
        rectangle "UserEntity\nRoleEntity\nPermissaoEntity\nUsuarioContatoEntity" as ENT1
        
        rectangle "ProdutoEntity\nProdutoComposicaoEntity" as ENT2
    }
    
    package "Multi-Tenancy Support" {
        rectangle "MultiTenantRoutingDataSource\nTenantContextInterceptor\nTenantSelector\nDatasource Pool per Tenant" as TENANT
    }
    
    package "Observability" {
        rectangle "@TrackFlow Aspect\nFlowEvent Publisher\nFlowEventRepository\nEvent Trackers\n├─ Database Tracker\n├─ Kafka Tracker\n└─ WebSocket Tracker" as OBS
    }
}

' ============================================================================
' DADOS
' ============================================================================

rectangle "💾 DATA LAYER" #F0F0F0 {
    package "Databases" {
        database "PostgreSQL\n(Tenant DataSources)" as PG
        database "PostgreSQL\n(Observability DB)" as OBS_DB
    }
    
    package "Message Brokers" {
        cloud "Kafka\n(Analytics & Events)" as KAFKA
    }
    
    package "Real-time Communication" {
        cloud "WebSocket\n(Push Events)" as WS
    }
}

' ============================================================================
' RELACIONAMENTOS E FLUXOS
' ============================================================================

' REST → Application
R1 --> DTO1 : validates
R5 --> DTO2 : validates
DTO1 --> VAL1 : passes through
VAL1 --> CMD : creates

' Commands → Handlers
CMD --> HAND : routes to
HAND --> ORCH : executes in context

' Handlers → Domain
HAND --> AGG1 : creates/updates
AGG1 --> BR : validates business rules
AGG1 --> DEVT : generates events

' Domain → Infrastructure
DEVT --> OBS : @TrackFlow captures
HAND --> REPO1 : delegates persistence
AGG1 --> MAP1 : converts via

' Mappers → Entities
MAP1 --> ENT1 : converts to
ENT1 --> REPO1 : persisted by

' Repositories → Database
REPO1 --> PG : stores User data
REPO2 --> PG : stores Produto data
TENANT -.-> PG : routes by tenant

' Multi-Tenancy Isolation
TENANT --> REPO1 : filters by tenantId
TENANT --> REPO2 : filters by tenantId

' Observability
ORCH -.-> OBS : @TrackFlow
OBS --> OBS_DB : stores events
OBS --> KAFKA : publishes events
OBS --> WS : sends real-time

' Queries
QRY --> REPO1 : reads from
REPO1 --> PG : queries
QRY --> R2 : returns to

' ============================================================================
' FLUXO DE REQUISIÇÃO COMPLETO
' ============================================================================

note bottom of R1
  **Exemplo: Criar Novo Usuário**
  
  1. POST /usuarios + CreateUserRequest
  2. Controller valida formato
  3. Cria CreateUserCommand
  4. CreateUserHandler orquestra
  5. User.create() em domínio puro
  6. Valida invariantes
  7. Gera UserCreatedEvent
  8. PopulateRepositoryJPA persiste
  9. UserMapper converte
 10. UserEntity vai para PostgreSQL
 11. @TrackFlow captura todo fluxo
 12. FlowEvent → Database + Kafka + WebSocket
 13. Response retorna com 201 Created
end note

' ============================================================================
' LEGENDA DE CORES
' ============================================================================

legend bottom
    |<#E6FFE6> Presentation: Interface com usuário (REST) |
    |<#E6F3FF> Application: Orquestração e CQRS |
    |<#FFFACD> Domain: Lógica de negócio pura |
    |<#FFE6E6> Infrastructure: Persistência técnica |
    |<#F0F0F0> Data: Armazenamento e mensagens |
endlegend

footer ERP Cloud - Arquitetura em Camadas | Fevereiro 2026

@enduml
