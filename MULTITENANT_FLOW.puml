@startuml ERP_Cloud_MultiTenant_Flow

!define COLOR_REQUEST #FFE66D
!define COLOR_FILTER #FF6B6B
!define COLOR_ROUTING #4ECDC4
!define COLOR_EXEC #95E1D3
!define COLOR_PERSIST #A8D8EA
!define COLOR_EVENT #F7DC6F

skinparam backgroundColor #FFFFFF
skinparam componentBackgroundColor #F5F5F5

title ERP Cloud - Multi-Tenancy & Observability Flow

' ============================================================================
' FASE 1: REQUEST INGRESS & TENANT RESOLUTION
' ============================================================================

rectangle "📥 REQUEST INGRESS & TENANT RESOLUTION" #FFE6E6 {
    component [HTTP Request] as REQ
    component [Extract Tenant Header] as ETH
    component [TenantContextInterceptor] as TCI
    component [TenantContext (ThreadLocal)] as TC
    component [Validate Tenant Active] as VAL
}

REQ --> ETH : X-Tenant-ID: 123
ETH --> TCI : tenant=123
TCI --> TC : store in ThreadLocal
TC --> VAL : check status

' ============================================================================
' FASE 2: DATASOURCE ROUTING
' ============================================================================

rectangle "🔀 DATASOURCE ROUTING" #FFE6E6 {
    component [Request Scoped] as RS
    component [MultiTenantRoutingDS] as MTDS
    component [DataSource Pool - Tenant A] as DSA
    component [DataSource Pool - Tenant B] as DSB
    component [DataSource Pool - Tenant C] as DSC
    component [Connection Pool] as CP
}

VAL --> RS : tenant validated
RS --> MTDS : lookup datasource
MTDS --> DSA : if tenant=A
MTDS --> DSB : if tenant=B
MTDS --> DSC : if tenant=C
DSA --> CP : establish connection
DSB --> CP : establish connection
DSC --> CP : establish connection

' ============================================================================
' FASE 3: BUSINESS LOGIC EXECUTION
' ============================================================================

rectangle "⚙️ BUSINESS LOGIC EXECUTION" #E6F3FF {
    component [Controller Handler] as CTRL
    component [@TrackFlow Aspect] as TRACK
    component [CommandHandler.execute()] as CMD_EXE
    component [TenantContext Active] as TC_ACTIVE
    component [Domain Logic] as DOM
    component [Generate Domain Events] as EVENTS
}

CP --> CTRL : SQL Pool ready for tenant
CTRL --> TRACK : intercept
TRACK --> CMD_EXE : aspect wraps
TC_ACTIVE -.-> CMD_EXE : every query uses TenantContext
CMD_EXE --> DOM : execute business logic
DOM --> EVENTS : publish events

' ============================================================================
' FASE 4: PERSISTÊNCIA COM ISOLAMENTO
' ============================================================================

rectangle "💾 PERSISTENCE WITH TENANT ISOLATION" #FFE6E6 {
    component [UserRepository.save()] as REPO_SAVE
    component [Add tenantId Filter] as FILTER
    component [UserMapper.convert()] as MAP
    component [UserEntity + tenant_id] as ENT
    component [Execute Query] as EXEC_Q
    component [Tenant A Database] as DB_A
    component [Tenant B Database] as DB_B
}

EVENTS --> REPO_SAVE : publish through repo
REPO_SAVE --> FILTER : validate tenant in where clause
FILTER --> MAP : map to entity
MAP --> ENT : entity.tenant_id = 123
ENT --> EXEC_Q : execute INSERT/UPDATE
MTDS -.-> EXEC_Q : route to correct datasource
EXEC_Q --> DB_A : INSERT tb_usuario (tenant_id=123)
EXEC_Q -.-> DB_B : NOT accessible to other tenants

' ============================================================================
' FASE 5: OBSERVABILITY & AUDITORIA
' ============================================================================

rectangle "👁️ OBSERVABILITY & AUDIT" #F0F0F0 {
    component [@TrackFlow Aspect] as TRACK_2
    component [Create FlowEvent] as FE_CREATE
    component [FlowEvent Data] as FE_DATA
    component [Multi-Tracker] as MT
    component [Database Tracker] as DT
    component [Kafka Tracker] as KT
    component [WebSocket Tracker] as WT
}

TRACK --> TRACK_2 : after execution
TRACK_2 --> FE_CREATE : capture success
FE_CREATE --> FE_DATA : with metadata
FE_DATA --> MT : publish to trackers

' ============================================================================
' FASE 6: OBSERVABILITY DESTINATIONS
' ============================================================================

rectangle "📡 OBSERVABILITY DESTINATIONS" #E6FFE6 {
    component [FlowEventRepository] as FLOW_REPO
    component [Observability DB\n(Shared)] as OBS_DB
    component [Kafka Topic:\nflow-events] as KAFKA_T
    component [Stream Processors] as STREAM
    component [Analytics Backend] as ANALYTICS
    component [WebSocket Server] as WS_SRV
    component [Admin Dashboard\n(Real-time)] as DASH
}

MT --> DT : database persistence
MT --> KT : event streaming
MT --> WT : real-time push

DT --> FLOW_REPO : store audit
FLOW_REPO --> OBS_DB : shared observability db\n(not tenant-isolated)

KT --> KAFKA_T : publish events
KAFKA_T --> STREAM : stream processing
STREAM --> ANALYTICS : dashboards & reports

WT --> WS_SRV : websocket push
WS_SRV --> DASH : admin sees requests in real-time

' ============================================================================
' FASE 7: RESPONSE
' ============================================================================

rectangle "📤 RESPONSE & CLEANUP" #E6FFE6 {
    component [Success Response] as RESP
    component [Clear TenantContext] as CLEAR_TC
    component [Close Connection] as CLOSE_CONN
}

DASH -.-> RESP : async UI update
OBS_DB -.-> RESP : audit complete
RESP --> CLEAR_TC : threadlocal cleanup
CLEAR_TC --> CLOSE_CONN : return to pool

' ============================================================================
' DATA MODELS & ISOLATION EXAMPLE
' ============================================================================

rectangle "🗂️ DATA ISOLATION EXAMPLE" {
    note right
        **Tenant A Database (a1.erp.com)**
        ```
        tb_usuario:
        id | tenant_id | email          | status
        1  | 123       | joao@a1.com    | ATIVO
        2  | 123       | maria@a1.com   | ATIVO
        ```
        
        **Tenant B Database (b2.erp.com)**
        ```
        tb_usuario:
        id | tenant_id | email          | status
        1  | 456       | pedro@b2.com   | ATIVO
        ```
        
        ✅ Usuários de A não conseguem ler B (data source diferente)
        ✅ Queries filtram sempre por tenant_id
        ✅ Isolamento lógico + físico
    end note
}

' ============================================================================
' SECURITY & MULTI-TENANCY MATRIX
' ============================================================================

rectangle "🔐 SECURITY MATRIX" {
    note right
        **Isolamento em 3 camadas:**
        
        1️⃣ **Conexão (Connection Pool)**
           └─ Cada tenant → DataSource dedicado
        
        2️⃣ **Query (SQL Filter)**
           └─ WHERE tenant_id = ? em toda query
        
        3️⃣ **Application (Business Logic)**
           └─ Validação adicional em Repository
        
        **Fluxo de uma requisição:**
        
        Headers: X-Tenant-ID: 123
           ↓
        TenantContextInterceptor (armazena em ThreadLocal)
           ↓
        Controller → Service → Repository
        (qualquer acesso a banco usa ThreadLocal)
           ↓
        MultiTenantRoutingDataSource
        (conecta ao pool correto: Tenant 123)
           ↓
        Repository adiciona: WHERE tenant_id = 123
           ↓
        SQL executado no PostgreSQL certo
           ↓
        FlowEvent registra: traceId, tenantId, userId, ação
           ↓
        Eventos publicados:
        - Database (auditoria)
        - Kafka (analytics)
        - WebSocket (UI tempo-real)
    end note
}

' ============================================================================
' FLUXO VISUAL
' ============================================================================

note bottom of REQ
  **Complete Request Flow:**
  
  Client Request (Header: X-Tenant-ID: 123)
        ↓
  TenantContextInterceptor extracts tenant
        ↓
  MultiTenantRoutingDataSource routes
        ↓
  ConnectionPool[Tenant 123] conecta
        ↓
  @TrackFlow Aspect envolve execução
        ↓
  CommandHandler executa lógica
        ↓
  Repository persiste + filtra by tenant_id
        ↓
  Queries dirigem ao DB correto
        ↓
  FlowEvent captura todo contexto
        ↓
  Event Trackers publicam
        ↓
  Database + Kafka + WebSocket
        ↓
  Response retorna + TenantContext limpa
end note

footer ERP Cloud - Multi-Tenancy & Observability Architecture | Fevereiro 2026

@enduml
